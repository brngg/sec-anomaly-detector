# SEC identity for EDGAR requests
SEC_IDENTITY="Your Name you@example.com"

# Company universe CSV (used by backfill)
COMPANIES_CSV="data/companies.csv"

# Runtime DB settings
DB_BACKEND=postgres
DATABASE_URL="postgresql://app_rw:password@db.example.supabase.co:6543/postgres?sslmode=require"
# DATABASE_URL_RW="postgresql://app_rw:password@db.example.supabase.co:6543/postgres?sslmode=require"
API_DATABASE_URL="postgresql://app_ro:password@db.example.supabase.co:6543/postgres?sslmode=require"
# DATABASE_URL_RO="postgresql://app_ro:password@db.example.supabase.co:6543/postgres?sslmode=require"

# API auth (optional)
# API_AUTH_ENABLED=1
# API_KEY="change-me"
# DEMO_API_KEY="change-me"

# Scoring
# RISK_SCORING_MODE="monthly_abnormal"
# RISK_DEFAULT_MODEL_VERSION="v2_monthly_abnormal"
# RISK_MODEL_VERSION=""
# RISK_MONTHLY_HISTORY_MONTHS=12

# Poller runtime controls
# POLL_ENABLE_INLINE_ANALYSIS=1
# POLL_ENABLE_RISK_SCORING=1
# POLL_ENABLE_CATCHUP=1
# POLL_CATCHUP_DAYS=2
# POLL_CATCHUP_COOLDOWN_HOURS=48
# POLL_LOOKBACK_DAYS=14
# POLL_CURRENT_PAGE_SIZE=100
# POLL_FEED_BUFFER_HOURS=6
# POLL_STALE_RUN_HOURS=6
# POLL_STALE_RUN_THRESHOLD_PCT=0.8
# POLL_SLEEP_SECONDS=0.11
# POLL_ADVISORY_LOCK_NAME="sec-daily-refresh"
# POLL_LOCK_PATH=".poller.lock"
# POLL_LOCK_TIMEOUT_SECONDS=0

# Backfill window controls (set one or both)
BACKFILL_START_DATE="2024-03-03"
BACKFILL_DAYS=730

# Dashboard runtime (optional)
# DASHBOARD_API_BASE_URL="http://127.0.0.1:8000"
# DASHBOARD_API_KEY=""
# DASHBOARD_DEFAULT_LIMIT=25
# DASHBOARD_REQUEST_TIMEOUT_SECONDS=20

# Misc
DRY_RUN=0
